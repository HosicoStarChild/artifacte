{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "allowImportingTsExtensions": true,
    "lib": ["es2020"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": ["mocha", "node", "chai"]
  },
  "include": ["./**/*.ts"]
}
